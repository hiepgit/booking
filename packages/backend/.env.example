# Healthcare Booking Backend - .env.example
# Sao chép file này thành .env và điền giá trị thật sự.
# Nếu dùng docker-compose trong repo này, DB mặc định:
#   POSTGRES_USER=username, POSTGRES_PASSWORD=password, POSTGRES_DB=healthcare_db
#   DATABASE_URL nên là: postgresql://username:password@localhost:5432/healthcare_db?schema=public

# Môi trường chạy: development | test | production
NODE_ENV=development

# Cổng backend (mặc định 3000)
PORT=3000

# Kết nối Postgres
DATABASE_URL=postgresql://username:password@localhost:5432/healthcare_db?schema=public

# Bật Swagger UI tại /docs (true/false)
SWAGGER_ENABLED=true

# Nguồn CORS được phép (web dev mặc định chạy cổng 3001)
CORS_ORIGIN=http://localhost:3001

# Rate limit (cửa sổ tính bằng ms, số request tối đa)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# JWT secrets (thay bằng chuỗi ngẫu nhiên, đủ dài)
JWT_ACCESS_SECRET=djnfbkjdsfjdfaksdjh
JWT_REFRESH_SECRET=jsakdhuwiasdhsakdkk

# SMTP cấu hình gửi email OTP (Ethereal mặc định, có thể để trống USER/PASS khi dev)
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# OTP: thời gian hết hạn (phút) và số lần thử tối đa
OTP_EXPIRES_MINUTES=10
OTP_MAX_ATTEMPTS=5
